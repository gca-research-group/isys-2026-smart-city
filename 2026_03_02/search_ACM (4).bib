@inproceedings{10.1145/3773274.3774256,
author = {Solino, Andr\'{e} and Batista, Thais and Cavalcante, Everton},
title = {An Autonomic Computing Approach for Scaling Cloud-Based Smart City Platforms},
year = {2026},
isbn = {9798400722851},
publisher = {Association for Computing Machinery},
address = {New York, NY, USA},
url = {https://doi-org.ez349.periodicos.capes.gov.br/10.1145/3773274.3774256},
doi = {10.1145/3773274.3774256},
abstract = {Smart city platforms often use cloud-based infrastructures that leverage containers and virtual machines to manage dynamic demands from diverse data sources, urban services, and users. However, traditional auto-scaling mechanisms in cloud environments typically focus on infrastructure-level metrics, which can result in delayed responses to performance bottlenecks. This paper presents a reactive auto-scaling approach based on the MAPE-K autonomic control loop that integrates infrastructure-level data with application-level metrics. Our approach enables the earlier identification of hotspots in the platform’s internal logic, which are often overlooked by traditional techniques. Our solution collects multi-level metrics in a non-intrusive manner to determine whether to scale resources vertically or horizontally before significant resource contention arises. We validated our approach in a real-world smart city platform that manages geospatial data and experiences highly variable workloads. Experimental results show that our solution can reduce reaction times and prevent unnecessary scaling actions.},
booktitle = {Proceedings of the 18th IEEE/ACM International Conference on Utility and Cloud Computing},
articleno = {1},
numpages = {10},
keywords = {Smart cities, Auto-scaling, Cloud computing, MAPE-K},
location = {
},
series = {UCC '25}
}

@inproceedings{10.1145/3774900.3776638,
author = {Melo, Paulo C\'{e}sar F. and Costa, F\'{a}bio M.},
title = {MDMWARE: Model-Driven Domain-Specific Middleware as a Tool for IT/OT Integration in the Context of Smart Cities},
year = {2025},
isbn = {9798400723032},
publisher = {Association for Computing Machinery},
address = {New York, NY, USA},
url = {https://doi-org.ez349.periodicos.capes.gov.br/10.1145/3774900.3776638},
doi = {10.1145/3774900.3776638},
abstract = {The concept of smart cities entails the use of information technologies to access the resources of a city in a more intelligent way by providing specialized services to citizens and city officials. In this way, the city's IT infrastructure should facilitate the development, deployment, and operation of smart city applications for diverse application domains. Building such applications is challenging since they are used on large-scale systems, have dynamic behavior, must access heterogeneous resources, and must deal with the semantics of different domains. We propose and evaluate an integrated approach for the development and execution of smart city applications in this context. To this end, we leverage a model-driven approach for domain-specific middleware, adding support for the development of applications in a platform-agnostic way using domain-specific building blocks. The proposed approach significantly reduces development complexity and enables the effective adaptation of domain-specific applications for different smart city platforms with adequate performance.},
booktitle = {Proceedings of the International Workshop on Middleware for IT/OT Integration},
pages = {25–30},
numpages = {6},
keywords = {Model-Driven Engineering, Domain-Specific Middleware, Semantic Gap, Smart City Platforms},
location = {
},
series = {MITOTI '25}
}

@article{10.1145/3769668,
author = {Pedroso, Carlos and Santos, Aldri},
title = {A Survey on Faults and Vulnerabilities in Network Topological Connectivity: Logical and Physical Perspectives},
year = {2025},
issue_date = {April 2026},
publisher = {Association for Computing Machinery},
address = {New York, NY, USA},
volume = {58},
number = {5},
issn = {0360-0300},
url = {https://doi-org.ez349.periodicos.capes.gov.br/10.1145/3769668},
doi = {10.1145/3769668},
abstract = {Topological connectivity is essential in networked environments, as it enables the efficient exchange of information between distributed devices and increases service reliability. The devices’ interconnection with different characteristics allows the formation of networks that function as infrastructures, facilitating the provision of multiple services essential to social well-being. In critical scenarios such as disasters, ensuring connectivity is vital for the effective transmission of crucial data, such as security and public transport notifications. This survey highlights the importance of resilient topological connectivity, which maintains communication among network nodes despite faults or disruptions. First, we explore the challenges posed by vulnerabilities and faults, whether benign or malicious, physical or logical, that may disrupt the topology, resulting in problems such as packet loss, transmission delays, and reduced service availability. Then, we review the literature to identify the main faults and solutions developed to provide resilience to topological connectivity in different network scenarios, such as IoT, WSN, and TSN. Solutions are categorized with a focus on strategies such as resistance, recovery, adaptation, absorption, both active and reactive, offering a comprehensive understanding of how to strengthen topology performance and availability.},
journal = {ACM Comput. Surv.},
month = nov,
articleno = {125},
numpages = {36},
keywords = {Topological connectivity, resilience}
}

@inproceedings{10.1145/3773274.3774701,
author = {De Oliveira Jarczewski, Rafael and Cerqueira, Eduardo and Bittencourt, Luiz Fernando and A. F. Loureiro, Antonio and A. Villas, Leandro and De Souza, Allan M.},
title = {Participation is Power: Effective Approach to Dynamic Federated Learning},
year = {2026},
isbn = {9798400722851},
publisher = {Association for Computing Machinery},
address = {New York, NY, USA},
url = {https://doi-org.ez349.periodicos.capes.gov.br/10.1145/3773274.3774701},
doi = {10.1145/3773274.3774701},
abstract = {Distributed systems have emerged as a fundamental approach for machine learning, particularly in contexts involving numerous interconnected devices, such as those found in the Internet of Things (IoT) and Smart Cities. Nevertheless, the consistent availability of these devices remains pivotal for practical training, the availability of these devices cannot be assured throughout the training process due to challenges like limited battery life, bandwidth constraints, or compliance obligations. To address these issues, we propose FedWIKP. This framework integrates client participation and knowledge preservation as a significant factor in the federated model, alongside a catch-up learning process at the client end to compensate for missed rounds, to alleviate the effects of participation fluctuations during federated training. Empirical evidence indicates that the proposed solution enhances the equilibrium between accuracy and data transmission by up to 2x and decreases data transmission volume by as much as 5x compared to literature methods, illustrating its efficacy in dynamic scenarios.},
booktitle = {Proceedings of the 18th IEEE/ACM International Conference on Utility and Cloud Computing},
articleno = {56},
numpages = {6},
keywords = {Federated Learning, Communication Efficiency, Dynamic Environments, Dynamic Participation},
location = {
},
series = {UCC '25}
}

