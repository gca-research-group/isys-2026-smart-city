@CONFERENCE{Teodoro2025641,
	author = {Teodoro, Carlos A.F. and Silva, Cristiano Maciel Da and de Souza, Fernanda Sumika Hojo},
	title = {Integrated Planning of Infrastructure and Drone Delivery Operations with Multiple Cycles},
	year = {2025},
