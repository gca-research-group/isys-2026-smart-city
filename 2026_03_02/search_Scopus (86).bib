	affiliations = {Universidade Estadual de Campinas, Campinas, SP, Brazil; Universidade Federal do Pará, Belem, PA, Brazil; Universidade Federal de Minas Gerais, Belo Horizonte, MG, Brazil; Universidade Estadual de Campinas, Campinas, SP, Brazil},
	abstract = {Distributed systems have emerged as a fundamental approach for machine learning, particularly in contexts involving numerous interconnected devices, such as those found in the Internet of Things (IoT) and Smart Cities. Nevertheless, the consistent availability of these devices remains pivotal for practical training, the availability of these devices cannot be assured throughout the training process due to challenges like limited battery life, bandwidth constraints, or compliance obligations. To address these issues, we propose FedWIKP. This framework integrates client participation and knowledge preservation as a significant factor in the federated model, alongside a catch-up learning process at the client end to compensate for missed rounds, to alleviate the effects of participation fluctuations during federated training. Empirical evidence indicates that the proposed solution enhances the equilibrium between accuracy and data transmission by up to 2x and decreases data transmission volume by as much as 5x compared to literature methods, illustrating its efficacy in dynamic scenarios. © 2025 Copyright is held by the owner/author(s). Publication rights licensed to ACM.},
