	affiliations = {University of Technology & Innovation, Bukit Jalil, Malaysia; Pontifícia Universidade Católica do Rio Grande do Sul, Management Graduate Program, Porto Alegre, RS, Brazil},
	abstract = {While smart cities are often driven by technological innovation and economic development, the dimensions of social cohesion and sustainable urbanization remain underexplored. A key research gap lies in how smart city initiatives address the digital divide, particularly in the Global South, where marginalized communities often lack access to digital infrastructure and digital skills. This study adopts a qualitative approach, using thematic analysis of academic literature and selected case studies to examine the impact of smart city efforts on social cohesion and digital inclusion. Findings highlight three core themes: the significance of inclusive governance frameworks, strategies to enhance digital accessibility and the role of digital literacy in fostering engagement. Although smart city initiatives can bridge socioeconomic divides, they risk reinforcing inequalities if digital exclusion is overlooked. This paper provides practical insights for policymakers and urban planners, advocating for inclusive, technology-integrated strategies that promote equitable and resilient urban futures © 2025 IEEE.},
