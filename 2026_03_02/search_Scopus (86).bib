@ARTICLE{Bitencourt202521679,
	author = {Bitencourt, Hugo Vinicius and Lucas, Patrícia De Oliveira E. and Orang, Omid and Silva, Petronio C.L. and Guimarães, Frederico Gadelha},
	title = {A Multistep Multivariate Fuzzy-Based Time-Series Forecasting on Internet of Things Data},
	year = {2025},
	journal = {IEEE Internet of Things Journal},
	volume = {12},
	number = {12},
