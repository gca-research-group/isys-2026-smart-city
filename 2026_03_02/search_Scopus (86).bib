	title = {Parallel Rendezvous Strategy for Node Association in Wi-SUN FAN Networks},
	year = {2025},
	journal = {Sensors},
	volume = {25},
	number = {19},
	pages = {},
	doi = {10.3390/s25196213},
	url = {https://www.scopus.com/inward/record.uri?eid=2-s2.0-105018920892&doi=10.3390%2Fs25196213&partnerID=40&md5=004afbcff284511358f87f80eac83526},
	affiliations = {Universidade Federal do Parana, Department of Electrical Engineering, Curitiba, PR, Brazil; Lactec Institutes, Curitiba, Brazil; Universidade Tecnológica Federal do Paraná, Graduate Program in Energy Systems, Curitiba, PR, Brazil; Universidad Tecnológica del Uruguay, Department of Information Technologies, Montevideo, Montevideo, Uruguay},
	abstract = {The Wi-SUN FAN (Wireless Smart Ubiquitous Network Field Area Network) standard facilitates large-scale connectivity among smart devices in utility networks and smart cities. Specifically designed for Low-Power and Lossy Networks (LLNs), Wi-SUN FAN supports the formation of multiple Personal Area Networks (PANs) and mesh topologies with multi-hop transmissions. However, the node association process, divided into five junction states, often results in prolonged connection times, particularly in multi-hop networks, thereby limiting network scalability and reliability. This study analyzes the factors affecting these delays, with a particular focus on Join State 1 (JS1), which relies on PAN Advertisement (PA) packets that use asynchronous communication and the trickle timer algorithm, frequently causing significant delays. To overcome this challenge in JS1, we propose the Parallel Rendezvous (PR) strategy, which forms synchronized clusters of unassociated nodes and leverages the standard’s PAN Advertisement Solicit (PAS) packets to rapidly disseminate network information. The proposed algorithm, PR Wi-SUN FAN, is evaluated through simulations in various network topologies, demonstrating notable improvements in linear, fully connected, and mesh scenarios. The most significant gains are observed in the linear topology, with reductions of up to 71.22% in association time and 59.56% in energy consumption during JS1. © 2025 by the authors.},
	author_keywords = {LLN; parallel rendezvous; trickle timer; Wi-SUN FAN},
	keywords = {Energy utilization; Information dissemination; Network topology; Timing circuits; Wireless local area networks (WLAN); Field area networks; Large-scales; Lossy networks; Low Power Networks; Network standards; Parallel rendezvous; Trickle timer; Ubiquitous networks; Wi-SUN FAN; Low power electronics; advertising; algorithm; article; controlled study; energy consumption; reliability; simulation; smart device},
	correspondence_address = {A.A. Quispe; Department of Electrical Engineering, Federal University of Paraná-UFPR, Curitiba, 81531-980, Brazil; email: ananias.quispe@lactec.com.br},
	publisher = {Multidisciplinary Digital Publishing Institute (MDPI)},
