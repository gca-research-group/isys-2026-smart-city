@CONFERENCE{Pita Costa2025509,
	author = {Pita Costa, João and Barrionuevo, Leonardo and Dine, Maša Kovič},
	title = {OBSERVING THE IMPACT OF AI IN THE PROGRESS OF THE SUSTAINABLE DEVELOPMENT GOAL 11},
	year = {2025},
	journal = {Proceedings of the International Conferences IADIS Information Systems 2025 and e-Society 2025},
	pages = {509 - 513},
	url = {https://www.scopus.com/inward/record.uri?eid=2-s2.0-105003180183&partnerID=40&md5=eba3779a48cb87860282948360b11805},
	affiliations = {Institut "Jožef Stefan", Ljubljana, Slovenia; MetAmazonia Academy, AMAGroup, Curitiba, Brazil; Univerza v Ljubljani, Ljubljana, Slovenia},
	abstract = {With Artificial Intelligence (AI) playing an increasingly pivotal role in shaping global development, it becomes imperative to thoroughly monitor and enhance its influence on the progress of the United Nations' Sustainable Development Goals (SDGs). This study undertakes a comprehensive analysis by implementing a SDG 11-focused AI-based Observatory offering a comprehensive framework for monitoring and evaluating the contributions of AI to sustainable development targeting topics that can enhance sustainable cities and communities worldwide. Drawing from four primary data sources-worldwide news, scientific publications, policy documents, and educational resources-the Observatory provides a multifaceted perspective on key issues such as urban planning, public transportation, circular economy, and civic engagement. Through the use of AI tools, the Observatory analyzes these data streams to support capacity building, policy development, and equitable access to AI, while identifying emerging trends and biases. The study highlights the growing significance of AI in shaping sustainable communities, with particular emphasis on the increased discussions for Community resillience. Global trends reveal a focus on ecosystem management, machine learning, and digital data, while regional case studies, such as the selected use case of the Brazilian Amazon, demonstrate a shift toward environmental preservation and leadership in climate-related initiatives supported by technological transformation. The findings underscore the need for region-specific approaches to sustainable development, ensuring that AI technologies themselves are aligned with Human Rights and equity considerations, as well as them being used in a way to contribute to respect them by urban stakeholders. The proposed framework goes beyond mere analysis by delivering actionable insights, equipping policymakers and innovators with the tools they need to drive future advancements. Ultimately, this work contributes to a more informed understanding of how AI can be strategically leveraged to accelerate progress toward achieving the SDG 11 goals, ensuring that technological innovation aligns with the global sustainability of cities and communities. © 2025 Proceedings of the International Conferences IADIS Information Systems 2025 and e-Society 2025. All rights reserved.},
	author_keywords = {Artificial Intelligence; Published Science Data-Driven Policy; SDG 11; Smart Cities; Sustainable Cities & Communities},
	keywords = {Circular economy; Sustainable development goals; Comprehensive analysis; Data driven; Global development; Primary data source; Published science data-driven policy; Science-data; Sustainable cities; Sustainable communities; Sustainable development goal 11; United Nations; Sustainable city},
	editor = {Nunes, M.B. and Isaias, P. and Powell, P. and Kommers, P. and Rodrigues, L.},
	publisher = {IADIS},
	isbn = {9789898704658},
	language = {English},
