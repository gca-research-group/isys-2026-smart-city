@ARTICLE{Ventura2025174,
	author = {Ventura, Heitor Tonel and Moretti, Raian De Almeida and Vendramin, Ana Cristina Kochem and Pigatto, Daniel Fernando},
	title = {Intrusion detection in vehicular networks using machine learning},
	year = {2025},
	journal = {Journal of Internet Services and Applications},
	volume = {16},
