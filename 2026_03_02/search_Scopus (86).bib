	pages = {641 - 648},
	doi = {10.1109/DCOSS-IoT65416.2025.00101},
	url = {https://www.scopus.com/inward/record.uri?eid=2-s2.0-105013851197&doi=10.1109%2FDCOSS-IoT65416.2025.00101&partnerID=40&md5=970947bac90adfde038eacfe6faee4fa},
	affiliations = {Universidade Federal de Ouro Preto, Department of Computing, Ouro Preto, MG, Brazil; Universidade Federal de Sao Joao del-Rei, Department of Technology, Sao Joao del Rei, MG, Brazil},
	abstract = {Using aerial deliveries by drones has been considered a promising option, given the growing demand for last-mile deliveries or emergency scenarios. This work proposes an optimization model for infrastructure planning and drone deliveries in multiple operating cycles. The optimization problem under study aims to determine the location of facilities and the allocation of demand from customers served using drones with payload and range capabilities over a set of periods. Each period represents an operating cycle of the drones, which can have their batteries recharged between cycles. The objective is to minimize the energy consumption of the drones while meeting the maximum coverage of the customers' demand, subject to operational feasibility in an urban scenario. The results demonstrated that the multi-period model could provide up to 29% wider demand coverage than the single-period model. The analysis of the number of customers being served showed that an additional up to 36% benefited from the introduction of multiple periods, indicating that lower-priority customers are more likely to be served. In cases where both models achieve full customer coverage, the multi-period model provided lower energy consumption of drones due to its planning flexibility. The contributions of this work indicate that it is possible to propose optimized logistics solutions that are more appropriate for the smart city scenario. © 2025 IEEE.},
	author_keywords = {drone deliveries; facility location; multi-period; optimization; Smart cities},
	keywords = {Antennas; Drones; Location; Sales; Smart city; Aerial delivery; Drone delivery; Emergency scenario; Facilities locations; Growing demand; Integrated planning; Last mile; Multi-period; Multiple cycles; Optimisations; Optimization},
