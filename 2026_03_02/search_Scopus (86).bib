	url = {https://www.scopus.com/inward/record.uri?eid=2-s2.0-105019704891&doi=10.1109%2FACCESS.2025.3624108&partnerID=40&md5=3ccf28ca02c22320c4d4eb9c5cf371f9},
	affiliations = {Universidade de São Paulo, Sao Paulo, SP, Brazil; Universidade do Estado do Rio de Janeiro, Department of Electrical Engineering, Rio de Janeiro, RJ, Brazil; Universidade Estadual de Campinas, Department of Systems and Energy, Campinas, SP, Brazil; Universidade Federal de Juiz de Fora, Department of Electrical Energy, Juiz de Fora, MG, Brazil; Universidade de São Paulo, Department of Electrical Engineering, Sao Paulo, SP, Brazil},
	abstract = {The concept of smart cities has evolved as a response to complex urban challenges, incorporating technological, environmental, economic, and institutional dimensions to improve urban quality of life and resilience. In parallel, the energy sector has undergone significant transformations driven by decarbonization, decentralization, and digitalization. Despite these advances, urban systems and energy infrastructure are still addressed as separate domains, limiting the understanding of how electricity systems support digital urban services in practice. This paper aims to provide an integrative overview of the relationship between smart cities and modern electrical systems. The contribution lies in articulating how key components such as smart grids, distributed energy resources, electric mobility, and digital technologies relate to urban governance, mobility, and service delivery. The analysis is based on a conceptual survey, exploring intersections, complementarities, and emerging patterns across both domains. The results underscore the mutual interdependence between energy and urban systems, emphasizing the importance of interoperability, coordinated planning, and infrastructure integration. By organizing these elements within a unified perspective, the paper reinforces the role of electricity as a structural pillar in the smart city context and supports the development of future interdisciplinary research, monitoring approaches, and policy design. © 2013 IEEE.},
