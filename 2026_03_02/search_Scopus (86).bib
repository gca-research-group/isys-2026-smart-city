@ARTICLE{Tondo2025335,
	author = {Tondo, Felipe Augusto and Montejo Sánchez, Samuel and Souza, R. D.},
	title = {Closeness Centrality-Based Scheduling for IoT Transmissions in LEO Satellite Networks},
	year = {2025},
	journal = {1st IEEE Latin American Conference on Internet of Things, LCIoT 2025 - Proceedings},
	pages = {335 - 338},
	doi = {10.1109/LCIoT64881.2025.11118577},
	url = {https://www.scopus.com/inward/record.uri?eid=2-s2.0-105016379310&doi=10.1109%2FLCIoT64881.2025.11118577&partnerID=40&md5=198a46a6e73fbd5cfe183f0dccc3b8d5},
	affiliations = {Universidade Federal de Santa Catarina, Department of Electrical and Electronic Engineering, Florianopolis, SC, Brazil; Universidad Tecnológica Metropolitana, Department of Electrical Engineering, Santiago, RM, Chile},
	abstract = {Low-Earth-Orbit (LEO) communication systems are fundamental for ubiquitous coverage, providing new opportunities in precision agriculture, smart cities, wildlife and environmental monitoring. In this context, it is very desirable that Internet of Things (IoT) devices can directly transmit information to LEO satellites. However, practical Direct-to-Satellite IoT (DtS-IoT) networks still require the development of modern and efficient multiple access protocols to support massive connectivity. For high-density scenarios, many devices appear simultaneously in the satellite footprint. Rise-based schemes like first-come-first-served (FCFS) can lead to considerably frequent collision events and thus reduced scheduling efficiency. This work presents a novel scheduling strategy for a DtS-IoT scenario, where a constellation of LEO satellites covers clustered IoT devices distributed across the target area. The proposed scheme utilizes the concept of closeness centrality to evaluate cluster transmission suitability and improve success probability, focusing on the shortest distance between IoT devices within that cluster and the satellite. Additionally, devices are equipped with a satellite trajectory predictor and utilize LoRa modulation to transmit data packets. Simulation results include real satellite orbits and demonstrate improvements in success probability comparing with a regular ALOHA (337.66%) protocol and the FCFS (83.15%) method for dense scenarios with hundreds of devices per cluster. © 2025 IEEE.},
	author_keywords = {Closeness centrality; DtS-IoT; LoRa; Scheduling},
	keywords = {Communication satellites; Internet of things; Internet protocols; Satellite communication systems; Closeness centralities; Communications systems; Direct-to-satellite IoT; Earth orbits; First come first served; Lora; Low earth orbit satellites; Precision Agriculture; Satellite network; Wildlife monitoring; Orbits},
	correspondence_address = {F.A. Tondo; Federal University of Santa Catarina (UFSC), Dept. of Electrical and Electronics Engineering, Florianópolis, Brazil; email: felipe.tondo@posgrad.ufsc.br},
	publisher = {Institute of Electrical and Electronics Engineers Inc.},
