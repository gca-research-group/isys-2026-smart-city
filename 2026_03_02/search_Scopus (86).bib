@CONFERENCE{Seixas202527,
	author = {Seixas, Nilton F.S. and Maia, Adriano H.O. and Pinto, George Pacheco and Tavares, Dhyego and Santos, Bruno P. and Machado, Ivan and De Almeida, Eduardo Santana D. and Durão, Frederico Araújo and Leone Maciel Peixoto, Maycon Leone Maciel and Figueiredo, Gustavo Bittencourt and Prazeres, Cássio Vinicius Serafim},
	title = {Bridging the Cost Gap: A Comprehensive Analysis of CAPEX and OPEX for Smart Home Transition from a Provider’s Perspective},
	year = {2025},
	journal = {International Conference on Internet of Things, Big Data and Security, IoTBDS - Proceedings},
	pages = {27 - 38},
	doi = {10.5220/0013201900003944},
	url = {https://www.scopus.com/inward/record.uri?eid=2-s2.0-105003720151&doi=10.5220%2F0013201900003944&partnerID=40&md5=c7fb82d97c6b7c00e7f1091be650d0c3},
	affiliations = {Universidade Federal da Bahia, Department of Computer Science, Salvador, BA, Brazil},
	abstract = {The urgency of addressing global warming has driven global efforts to enhance energy efficiency and transform energy acquisition methods. In this context, the adoption of smart technologies has gained relevance across various domains, including smart cities and smart homes. While smart cities are often promoted through government initiatives, transforming conventional homes into smart homes largely depends on consumer adoption. However, there is a significant gap in the literature regarding the implementation costs and benefits of this transition, with many studies focused on unrealistic scenarios tailored to the average American consumer profile. This study aims to fill that gap by proposing a methodology to estimate the conversion of conventional homes into smart homes, accounting for both capital expenditures (CAPEX) and operational expenditures (OPEX). The proposed approach seeks to enable an affordable transition for a wider range of consumer profiles. Four case studies are presented to demonstrate how smart systems can be integrated into homes, maximizing economic and environmental benefits for end-users. Additionally, the paper analyzes the commercial relationship between manufacturers and smart environment providers, exploring acquisition and operational cost models. As an alternative to the traditional device-based business model, the study suggests a subscription-based system, supported by the continuous delivery of smart solutions, promoting greater customer retention and scalability. © © 2025 by SCITEPRESS - Science and Technology Publications, Lda.},
	author_keywords = {CAPEX; IoT; OPEX; Smart Grids; Smart Homes},
	keywords = {Behavioral research; Engineering education; Capital expenditures; Comprehensive analysis; Consumer adoptions; Energy; Government initiatives; IoT; Operational expenditures; Smart grid; Smart homes; Smart technology; Cost benefit analysis},
