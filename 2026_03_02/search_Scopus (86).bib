	affiliations = {Universidade Federal de Goiás, Goiania, GO, Brazil},
	abstract = {The concept of smart cities entails the use of information technologies to access the resources of a city in a more intelligent way by providing specialized services to citizens and city officials. In this way, the city's IT infrastructure should facilitate the development, deployment, and operation of smart city applications for diverse application domains. Building such applications is challenging since they are used on large-scale systems, have dynamic behavior, must access heterogeneous resources, and must deal with the semantics of different domains. We propose and evaluate an integrated approach for the development and execution of smart city applications in this context. To this end, we leverage a model-driven approach for domain-specific middleware, adding support for the development of applications in a platform-agnostic way using domain-specific building blocks. The proposed approach significantly reduces development complexity and enables the effective adaptation of domain-specific applications for different smart city platforms with adequate performance. © 2025 Copyright is held by the owner/author(s). Publication rights licensed to ACM.},
	author_keywords = {Domain-Specific Middleware; Model-Driven Engineering; Semantic Gap; Smart City Platforms},
