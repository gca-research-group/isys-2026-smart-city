@article{ WOS:001441772600001,
Author = {Novo, Carolina Cardoso and Mexas, Mirian Picinini and Meza, Lidia Angulo},
Title = {Applications of cyber insurance in smart cities: a systematic literature
   review},
Journal = {INTERNATIONAL JOURNAL OF INFORMATION SECURITY},
Year = {2025},
Volume = {24},
Number = {2},
Month = {MAR 11},
Abstract = {Smart cities are essential for modern urban development, offering
   numerous benefits. However, they also present significant cyber risks
   that require special attention. Mitigating these risks demands
   continuous efforts and innovative solutions. Since no solution can
   eliminate vulnerabilities, cyber insurance stands out as a protective
   mechanism against financial losses. Therefore, this study aims to
   highlight the relationship between cyber insurance and cyber risks in
   smart cities within the existing literature. To achieve this, a
   systematic literature review was conducted using the Scopus and Web of
   Science databases, selecting 38 articles for analysis. This study is the
   first review that links cyber insurance to smart cities, presenting
   findings that offer an overview of the main approaches used. Notable
   applications of cyber insurance include critical infrastructures,
   specific technological contexts, and strategies for cyber risk
   management and innovation. The research provides suggestions for further
   investigations and developments in the field.},
